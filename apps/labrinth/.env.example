# ==================== BBSMC 后端环境变量示例 ====================
# 复制此文件为 .env 并根据实际情况修改
#
# 重要说明：
# - 构建阶段（GitHub Actions / Docker build）必须使用 Modrinth 官方地址
#   否则构建时无法访问自定义域名会导致编译失败
# - 运行阶段（生产环境）请替换为你自己的域名

# ==================== 基础配置 ====================
DEBUG=false                                    # 调试模式（生产环境设为 false）
RUST_LOG=info,sqlx::query=warn                 # 日志级别
SENTRY_DSN=none                                # Sentry 错误监控 DSN

# ==================== 站点配置 ====================
# 构建阶段使用 Modrinth 官方地址（防止编译失败）
# 生产环境运行时改为: https://bbsmc.org.cn
SITE_URL=https://modrinth.com
# 构建阶段使用 Modrinth 官方地址（防止编译失败）
# 生产环境运行时改为: https://cdn.bbsmc.org.cn/bbsmc
CDN_URL=https://cdn.modrinth.com
CDN_PRIVATE_URL=none                           # 私有 CDN 地址
# 构建阶段使用 Modrinth 官方地址（防止编译失败）
# 生产环境运行时改为: https://api.bbsmc.org.cn
SELF_ADDR=https://api.modrinth.com

# ==================== 管理密钥 ====================
# 请务必修改为随机字符串！可使用: openssl rand -hex 16
LABRINTH_ADMIN_KEY=change_me_to_random_string
RATE_LIMIT_IGNORE_KEY=change_me_to_random_string

# ==================== 数据库 (PostgreSQL) ====================
# 本地开发: postgresql://labrinth:labrinth@localhost/labrinth
# Docker 部署: postgresql://labrinth:PASSWORD@postgres:5432/labrinth
DATABASE_URL=postgresql://labrinth:labrinth@localhost/labrinth
DATABASE_MIN_CONNECTIONS=0
DATABASE_MAX_CONNECTIONS=16

# ==================== Meilisearch 搜索引擎 ====================
MEILISEARCH_ADDR=http://localhost:7700
MEILISEARCH_KEY=modrinth

# ==================== Redis 缓存 ====================
REDIS_URL=redis://localhost
REDIS_MAX_CONNECTIONS=10000
REDIS_NAMESPACE=none
REDIS_WAIT_TIMEOUT_MS=none

# ==================== 服务绑定 ====================
# 本地开发: 127.0.0.1:8000
# Docker 部署: 0.0.0.0:8000
BIND_ADDR=127.0.0.1:8000

# ==================== 通知 Webhook ====================
MODERATION_SLACK_WEBHOOK=
PUBLIC_DISCORD_WEBHOOK=
CLOUDFLARE_INTEGRATION=false

# ==================== 文件存储 ====================
# 存储后端: local / s3 / backblaze
STORAGE_BACKEND=local
MOCK_FILE_PATH=/tmp/modrinth

# ----- S3 存储（可选）-----
S3_ACCESS_TOKEN=none
S3_SECRET=none
S3_URL=none
S3_REGION=none
S3_BUCKET_NAME=none
S3_PRIVATE_BUCKET_NAME=none

# ----- Backblaze B2 存储（可选）-----
BACKBLAZE_KEY_ID=none
BACKBLAZE_KEY=none
BACKBLAZE_BUCKET_ID=none

# ==================== 索引间隔（秒）====================
LOCAL_INDEX_INTERVAL=3600                      # 1 小时
VERSION_INDEX_INTERVAL=1800                     # 30 分钟

# ==================== 速率限制 ====================
RATE_LIMIT_IGNORE_IPS='["127.0.0.1"]'

# ==================== 域名白名单 ====================
# 构建阶段包含 Modrinth 官方域名，生产环境按需添加自定义域名
WHITELISTED_MODPACK_DOMAINS='["cdn.modrinth.com", "cdn.bbsmc.org.cn", "github.com", "raw.githubusercontent.com"]'
ALLOWED_CALLBACK_URLS='["localhost", ".modrinth.com", ".bbsmc.org.cn", "127.0.0.1"]'

# ==================== OAuth 第三方登录（可选）====================
# GitHub OAuth
GITHUB_CLIENT_ID=none
GITHUB_CLIENT_SECRET=none

# GitLab OAuth
GITLAB_CLIENT_ID=none
GITLAB_CLIENT_SECRET=none

# Discord OAuth
DISCORD_CLIENT_ID=none
DISCORD_CLIENT_SECRET=none

# Microsoft OAuth
MICROSOFT_CLIENT_ID=none
MICROSOFT_CLIENT_SECRET=none

# Google OAuth
GOOGLE_CLIENT_ID=none
GOOGLE_CLIENT_SECRET=none

# ==================== 支付（可选）====================
# PayPal
PAYPAL_API_URL=https://api-m.sandbox.paypal.com/v1/
PAYPAL_WEBHOOK_ID=none
PAYPAL_CLIENT_ID=none
PAYPAL_CLIENT_SECRET=none

# Stripe
STRIPE_API_KEY=none
STRIPE_WEBHOOK_SECRET=none

# 七支付（国内支付平台）
SEVENPAY_API_URL=none
SEVENPAY_CREATE_ORDER_PATH=none
SEVENPAY_QUERY_ORDER_PATH=none
SEVENPAY_VERIFY_MERCHANT_PATH=none
SEVENPAY_KEYCODE=none
SEVENPAY_ALLOWED_IPS=none

# ==================== ClickHouse 分析数据库 ====================
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=staging_ariadne

# ==================== 邮件 SMTP ====================
SMTP_USERNAME=none
SMTP_PASSWORD=none
SMTP_HOST=none

# 站点路径（邮件中的链接）
SITE_VERIFY_EMAIL_PATH=none
SITE_RESET_PASSWORD_PATH=none
SITE_BILLING_PATH=none

# ==================== 验证码 ====================
HCAPTCHA_SECRET=none                           # hCaptcha 密钥
TAC_URL=none                                   # 腾讯验证码地址

# ==================== 分析与监控 ====================
# 构建阶段包含 Modrinth 官方域名，生产环境按需添加自定义域名
ANALYTICS_ALLOWED_ORIGINS='["http://127.0.0.1:3000", "http://localhost:3000", "https://modrinth.com", "https://www.modrinth.com", "https://bbsmc.org.cn", "https://www.bbsmc.org.cn", "*"]'

MAXMIND_LICENSE_KEY=none                        # MaxMind GeoIP 许可证
FLAME_ANVIL_URL=none                           # Flame Anvil 地址

# ==================== 其他第三方服务 ====================
ADITUDE_API_KEY=none                           # 广告
PYRO_API_KEY=none                              # Pyro 服务
BEEHIIV_PUBLICATION_ID=none                    # 邮件订阅
BEEHIIV_API_KEY=none

STEAM_API_KEY=none                             # Steam

TREMENDOUS_API_URL=https://testflight.tremendous.com/api/v2/
TREMENDOUS_API_KEY=none
TREMENDOUS_PRIVATE_KEY=none
TREMENDOUS_CAMPAIGN_ID=none

# ==================== 通知机器人 ====================
FEISHU_BOT_WEBHOOK=none                        # 飞书机器人 Webhook

# ==================== 阿里云短信 ====================
ALIYUN_SMS_ACCESS_KEYID=none
ALIYUN_SMS_ACCESS_KEY_SECRET=none
ALIYUN_SMS_REGION=none
ALIYUN_SMS_REPORT_TEMPLETE_CODE=none
ALIYUN_SMS_SIGN_NAME=none

# ==================== 火山引擎 ====================
HUOSHAN_AK=none
HUOSHAN_SK=none

# ==================== 安全 ====================
# 敏感数据加密密钥（32字节 Base64 编码，用于加密商户密钥等）
# 生成方法: openssl rand -base64 32
ENCRYPTION_KEY=none

# ==================== 开发模式 ====================
DEV=false                                      # 开发模式（生产环境设为 false）
